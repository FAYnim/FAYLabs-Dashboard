Options -Indexes
Options +FollowSymLinks

RewriteEngine On
RewriteBase /faydev/faylabs-dashboard/public/

# Route /projects/{slug} -> /projects/detail.php?slug={slug}
RewriteRule ^projects/([a-z0-9\-]+)/?$ projects/detail.php?slug=$1 [L,QSA]

# Route /projects -> /projects/index.php
RewriteRule ^projects/?$ projects/index.php [L,QSA]
